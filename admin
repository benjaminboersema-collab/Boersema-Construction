backend:
  name: github
  repo: benjaminboersema-collab/Boersema-Construction
  branch: main

media_folder: "images"
public_folder: "/images"

collections:
  - name: "projects"
    label: "Projects"
    folder: "_data/projects"
    create: true
    slug: "{{slug}}"
    fields:
      - { label: "Project Title", name: "title", widget: "string" }
      - label: "Category"
        name: "category"
        widget: "select"
        options:
          - "Residential — New Build"
          - "Residential — Renovation"
          - "Commercial — New Build"
          - "Commercial — Renovation"
          - "Industrial"
          - "Interior — Renovation"
          - "Exterior — Stonework"
      - { label: "Short Description", name: "description", widget: "string" }
      - { label: "Project Photo", name: "image", widget: "image" }
      - { label: "Featured (wide card)", name: "featured", widget: "boolean", default: false }

  - name: "settings"
    label: "Site Settings"
    files:
      - name: "general"
        label: "General Settings"
        file: "settings.json"
        fields:
          - { label: "Phone Number", name: "phone", widget: "string" }
          - { label: "WhatsApp Number (no + or spaces)", name: "whatsapp", widget: "string" }
          - { label: "Email Address", name: "email", widget: "string" }
          - { label: "Hero Headline", name: "hero_headline", widget: "string" }
          - { label: "Hero Tagline", name: "hero_tagline", widget: "string" }
          - { label: "Hero Body Text", name: "hero_body", widget: "text" }
          - { label: "About Paragraph 1", name: "about_p1", widget: "text" }
          - { label: "About Paragraph 2", name: "about_p2", widget: "text" }

<!doctype html>
<html>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Boersema Construction — Admin</title>
  <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
</head>
<body>
  <script src="https://unpkg.com/decap-cms@^3.0.0/dist/decap-cms.js"></script>
</body>
</html>
